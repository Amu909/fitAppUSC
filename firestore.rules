rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function currentUserPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function currentUserRole() {
      return isSignedIn() && exists(currentUserPath())
        ? get(currentUserPath()).data.role
        : null;
    }

    function isAdmin() {
      return currentUserRole() == 'admin';
    }

    function isBootstrapAdmin(userId) {
      return isOwner(userId)
        && request.auth.token.email == 'admin@fitapp.com';
    }

    function isTrainer() {
      return currentUserRole() == 'trainer';
    }

    match /users/{userId} {
      allow create: if (
          isAdmin()
          && request.resource.data.uid == userId
          && request.resource.data.role in ['member', 'trainer', 'admin']
        )
        || (
          isOwner(userId)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.email == request.auth.token.email
          && (
            request.resource.data.role == 'member'
            || (
              isBootstrapAdmin(userId)
              && request.resource.data.role == 'admin'
            )
          )
        );

      allow read: if isOwner(userId) || isAdmin();

      allow update: if isAdmin()
        || (
          isBootstrapAdmin(userId)
          && resource.data.email == request.auth.token.email
          && request.resource.data.role == 'admin'
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.email == resource.data.email
        )
        || (
          isOwner(userId)
          && request.resource.data.role == resource.data.role
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.email == resource.data.email
        );

      allow delete: if isAdmin();
    }

    match /routines/{routineId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() || isTrainer();
    }

    match /progress/{progressId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || isTrainer();
    }

    match /nutrition_plans/{planId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() || isTrainer();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
